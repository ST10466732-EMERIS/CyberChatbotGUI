<Window x:Class="CyberChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberGuard - Cybersecurity Awareness Chatbot (Part 2)" 
        Height="650" Width="850"
        Background="#FF1E1E1E" Foreground="White"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <!-- Main Chat Layout -->
        <!-- Header -->
        <Border Background="#FF007ACC" Height="60" VerticalAlignment="Top">
            <TextBlock Text="🛡️ CyberGuard Chatbot - Stay Safe Online!" 
                       FontSize="28" FontWeight="Bold" 
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="White"/>
        </Border>

        <!-- Chat Display -->
        <RichTextBox x:Name="chatDisplay" Margin="20,80,20,90" IsReadOnly="True" 
                     Background="#FF2D2D2D" Foreground="#E0E0E0" FontSize="15"
                     FontFamily="Consolas" BorderThickness="2" BorderBrush="#FF007ACC"/>

        <!-- Input Area -->
        <TextBox x:Name="txtInput" Margin="20,0,130,20" Height="55" VerticalAlignment="Bottom"
                 Background="#FF3D3D3D" Foreground="White" FontSize="16"
                 KeyDown="txtInput_KeyDown" Padding="10"/>

        <Button Content="Send" Margin="0,0,20,20" Width="100" Height="55" 
                VerticalAlignment="Bottom" HorizontalAlignment="Right"
                Background="#FF007ACC" Foreground="White" FontWeight="Bold" FontSize="16"
                Click="SendButton_Click"/>
    </Grid>
    <!-- Final UI version -->
</Window>